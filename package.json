{
  "name": "recipe-cards",
  "version": "0.1.0",
  "description": "Scannt YAML-Rezepte und rendert druckfertige A5-Rezeptkarten via Typst.",
  "type": "module",
  "bin": {
    "recipe-cards": "scripts/cli.ts"
  },
  "scripts": {
    "start": "node scripts/cli.ts",
    "images": "node scripts/gen-images.ts",
    "import": "node scripts/import-photo.ts",
    "add": "node scripts/add.ts",
    "refresh": "node scripts/refresh.ts",
    "bot": "node scripts/bot.ts",
    "seed": "node scripts/seed-from-drive.ts",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "prepare": "svelte-kit sync"
  },
  "engines": {
    "node": ">=23.6"
  },
  "dependencies": {
    "@auth/sveltekit": "^1.11.2",
    "better-sqlite3": "^12.10.0",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.65.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pngjs": "^6.0.5",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
