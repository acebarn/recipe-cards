# Kopiere diese Datei zu .env und trage deine Keys ein.

# Pixazo (Bildgenerierung, npm run images): Dashboard → API Key
PIXAZO_API_KEY=dein-key-hier

# Google Gemini (Foto-Import, npm run import): https://aistudio.google.com/apikey
GEMINI_API_KEY=dein-key-hier

# --- Web-App (SvelteKit) ---
# Auth.js: zufälliges Secret (z.B. `openssl rand -base64 32`)
AUTH_SECRET=
# Google OAuth (Google Cloud Console → OAuth-Client „Web"):
#   Authorized redirect URI: http://localhost:5173/auth/callback/google  (Dev)
#                            https://recipes.alessiobisgen.de/auth/callback/google  (Prod)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Öffentliche URL der App (hinter Proxy nötig, z.B. für Auth-Callbacks)
ORIGIN=http://localhost:5173

# Pfad zur SQLite-DB (Standard: <projectRoot>/data/library.db)
# RECIPE_DB_PATH=/data/library.db
# Projekt-Root für Typst/Assets (Standard: Repo-Wurzel; im Container: /app)
# RECIPE_PROJECT_ROOT=/app

# --- Drive-Backup-Sync (rclone) ---
# Worker nur aktiv bei RECIPE_SYNC=1 (verhindert versehentliche Drive-Writes lokal)
# RECIPE_SYNC=1
DRIVE_REMOTE=drive
DRIVE_FOLDER=Rezepte
# SYNC_INTERVAL_MS=30000

# --- nur lokale Entwicklung ---
# Umgeht den OAuth-Flow und meldet dich als diese (existierende) DB-Mail an:
# RECIPE_DEV_USER=alessio.bisgen@gmail.com
